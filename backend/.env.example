# Conexão com o banco de dados (MongoDB)
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?appName=<app>
DATABASE_URL="mongodb+srv://usuario:senha@cluster.mongodb.net/NomeDoBanco?appName=StudIA"

# Chave da API do Google Gemini
# Obtenha gratuitamente em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="sua-chave-gemini-aqui"
